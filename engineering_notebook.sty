\ProvidesPackage{engineering_notebook}[Engineering Notebook Template]

% ==============================================================================
% ENGINEERING NOTEBOOK CUSTOM COMMANDS
% ==============================================================================
% This package defines all the necessary commands to style the engineering notebook.
% All notebook-specific formatting is encapsulated in macros starting with \notebook...
% You can redefine any of these commands to customize the output without modifying
% the JSON-to-LaTeX converter logic.
%
% \notebookbold{text}                                     : Applies bold formatting
% \notebookitalic{text}                                   : Applies italic formatting
% \notebooktextcolor{hex}{text}                           : Applies text color (HTML hex format)
% \notebookinlinecode{text}                               : Applies inline code styling
% \notebookdecoration{color}{underline}{strikeout}{text}  : Applies highlights/lines
% \notebooksuperscript{text}                              : Applies superscript (with native word-wrapping)
% \notebooksubscript{text}                                : Applies subscript (with native word-wrapping)
% \notebookcharsplit{text}                                : Splits abnormally long unbreakable words at spaces in order to allow line wrapping
% \notebookheader{formatted}{raw}{level}{label}           : Section headers and TOC entries
% \notebookentry{title}{date}{author}{phase}{label}       : Notebook entry titles
% \notebookimage{file}{title}{caption}{width}{label}      : Standardized figures
% \begin{notebookcodeblock}{lang}{title}{caption}{label}  : Standardized code blocks
% \notebooktable{columns}{title}{content}{caption}{label} : Standardized tables
% \notebookequation{math}{title}{caption}{label}          : Standardized block equations
% ==============================================================================

