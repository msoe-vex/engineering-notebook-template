% Inline Code Styling
\definecolor{nbcodebg}{HTML}{EEEEEE}
\definecolor{nbcodeborder}{HTML}{C4C7C5}

\DeclareRobustCommand{\notebookinlinecode}{%
  \bgroup
  \small\ttfamily
  \markoverwith{%
    \rlap{\textcolor{nbcodebg}{\rule[-0.3ex]{2pt}{2.5ex}}}%
    \rlap{\textcolor{nbcodeborder}{\rule[2.2ex]{2pt}{0.4pt}}}%
    \rlap{\textcolor{nbcodeborder}{\rule[-0.3ex]{2pt}{0.4pt}}}%
    \rule{2pt}{0pt}%
  }%
  \ULon
}

% ulem-based rich text formatter
% #1 = highlight color (hex), #2 = underline (1/0), #3 = strikeout (1/0)
\DeclareRobustCommand{\notebookdecoration}[3]{%
  \bgroup
  \def\nbhlcolor{#1}%
  \def\nbhasul{#2}%
  \def\nbhasst{#3}%
  \markoverwith{%
    \ifx\nbhlcolor\empty\else
      \rlap{\textcolor[HTML]{\nbhlcolor}{\rule[-.3ex]{2pt}{2.5ex}}}%
    \fi
    \ifnum\nbhasul=1
      \rlap{\rule[-.3ex]{2pt}{0.4pt}}%
    \fi
    \ifnum\nbhasst=1
      \rlap{\rule[0.5ex]{2pt}{0.4pt}}%
    \fi
    \rule{2pt}{0pt}%
  }%
  \ULon
}

% Scripts and character splitting
% These map over characters natively so that un-breakable strings word-wrap perfectly
\ExplSyntaxOn
\NewDocumentCommand{\notebookcharsplit}{m}
 {
  \seq_set_split:Nnn \l_tmpa_seq { ~ } { #1 }
  \seq_map_inline:Nn \l_tmpa_seq 
   {
    \tl_map_inline:nn { ##1 } { ####1 \allowbreak }
    \c_space_tl
   }
  \unskip
 }

\NewDocumentCommand{\notebooksuperscript}{m}
 {
  \seq_set_split:Nnn \l_tmpa_seq { ~ } { #1 }
  \seq_map_inline:Nn \l_tmpa_seq 
   {
    \tl_map_inline:nn { ##1 } { \textsuperscript{####1} \allowbreak }
    \c_space_tl
   }
  \unskip
 }

\NewDocumentCommand{\notebooksubscript}{m}
 {
  \seq_set_split:Nnn \l_tmpa_seq { ~ } { #1 }
  \seq_map_inline:Nn \l_tmpa_seq 
   {
    \tl_map_inline:nn { ##1 } { \textsubscript{####1} \allowbreak }
    \c_space_tl
   }
  \unskip
 }
\ExplSyntaxOff

