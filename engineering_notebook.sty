% Helper command for formatted links
% Usage: \notebooklink{text}{type}{uuid/url}
% Supported types: entry, heading, image, table, codeBlock, url
\newcommand{\notebooklink}[3]{%
    \ifboolexpr{test {\ifstrequal{#2}{url}}}{%
        \href{\detokenize{#3}}{#1\ \lbrack\nolinkurl{\detokenize{#3}}\rbrack}%
    }{%
    \ifboolexpr{test {\ifstrequal{#2}{entry}} or test {\ifstrequal{#2}{heading}}}{%
        \hyperref[#3]{#1\ \lbrack\nameref*{#3},~p.\,\pageref*{#3}\rbrack}%
    }{%
    \ifboolexpr{test {\ifstrequal{#2}{resource}}}{%
        \hyperref[#3]{#1}%
    }{%
    \ifboolexpr{test {\ifstrequal{#2}{image}} or test {\ifstrequal{#2}{table}} or test {\ifstrequal{#2}{codeBlock}} or test {\ifstrequal{#2}{mathBlock}}}{%
        \hyperref[#3]{#1\ \lbrack\cref*{#3},~p.\,\pageref*{#3}\rbrack}%
    }{%
        \hyperref[#3]{#1}%
    }}}}%
}

% Backward-compatible wrappers for older generated LaTeX files
\newcommand{\resourcelink}[2][]{\notebooklink{#2}{resource}{#1}{}}
\newcommand{\entrylink}[2][]{\notebooklink{#2}{entry}{#1}{}}
\newcommand{\headinglink}[2][]{\notebooklink{#2}{heading}{#1}{}}

% Command to output a header with UUID label
% Usage: \notebookheader{formattedText}{plainText}{level}{uuid}
% #1 = formatted text (rich marks for display)
% #2 = plain text (safe for TOC and PDF bookmarks)
% #3 = level: 1 = subsection, 2 = subsubsection, etc.
% #4 = UUID label for cross-referencing
\newcommand{\notebookheader}[4]{%
    \ifnum#3=1\relax
        \subsection[\texorpdfstring{\notebookcharsplit{#2}}{#2}]{\phantomsection\label{#4}#1}%
    \else
        \subsubsection[\texorpdfstring{\notebookcharsplit{#2}}{#2}]{\phantomsection\label{#4}#1}%
    \fi
}
