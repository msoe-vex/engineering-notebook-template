% Helper to render a phase in the legend
\newcommand{\notebookphase}[3]{%
    {\color{#1}\hrule height 6pt}\smallskip
    \textbf{#2:} #3\par
    \vspace{0.5cm}
}

% Command to start a new entry
% Usage: \newentry{Title}{Date}{Author}{PhaseID}{uuid}
\newcommand{\notebookentry}[5]{%
    \clearpage
    \gdef\@entrytitle{#1}%
    \renewcommand{\@entrydate}{#2}
    \renewcommand{\@entryauthor}{#3}
    \renewcommand{\@entryphase}{\getphasename{#4}}
    \renewcommand{\@entryphasecolor}{\getphasecolor{#4}}

    \stepcounter{tocentrycount}
    \edef\tempcolor{\getphasecolor{#4}}
    \refstepcounter{section}
    \addtocontents{toc}{\protect\colorlet{toccolor-\thesection}{\tempcolor}}
    \phantomsection
    \protected@edef\@currentlabelname{#1}%
    \label{#5}%
    \section*{\notebookcharsplit{#1} \hfill \normalfont\small #2}
    \leavevmode\par\vspace{-\baselineskip}
    \addcontentsline{toc}{section}{%
        \texorpdfstring{%
            \protect\colorbox{toccolor-\thesection}{\makebox[0pt][l]{\hspace{-3pt}\rule[-4pt]{0pt}{14pt}}}%
            \hspace{6pt}%
            \textbf{\notebookcharsplit{#1}} \protect\textcolor{gray}{(#2)}%
        }{#1}%
    }
    \vspace{-0.2cm}

    {\color{\@entryphasecolor}\hrule height 6pt}\smallskip
    {\noindent \small \textbf{Author:} \@entryauthor \hfill \textbf{Phase:} \@entryphase}\par
    \medskip
}

% Legend Page
