% Helper to get phase color (expandable)
\newcommand{\getphasecolor}[1]{%
    \ifcsdef{phasecolor@#1}{\csuse{phasecolor@#1}}{PhaseDefault}%
}

% Helper to get phase name (expandable)
\newcommand{\getphasename}[1]{%
    \ifcsdef{phasename@#1}{\csuse{phasename@#1}}{#1}%
}

% Commands to set current entry info
\newcommand{\@entrytitle}{}
\newcommand{\@entrydate}{}
\newcommand{\@entryauthor}{}
\newcommand{\@entryphase}{}
\newcommand{\@entryphasecolor}{PhaseDefault}

% Helper to render a phase in the legend
\newcommand{\notebookphase}[3]{%
    {\color{#1}\hrule height 6pt}\smallskip
    \textbf{#2:} #3\par
    \vspace{0.5cm}
}

% Command to start a new entry
% Usage: \newentry{Title}{Date}{Author}{PhaseID}{uuid}
\newcommand{\notebookentry}[5]{%
    \clearpage
    \gdef\@entrytitle{#1}%
    \renewcommand{\@entrydate}{#2}
    \renewcommand{\@entryauthor}{#3}
    \renewcommand{\@entryphase}{\getphasename{#4}}
    \renewcommand{\@entryphasecolor}{\getphasecolor{#4}}

    \stepcounter{tocentrycount}
    \edef\tempcolor{\getphasecolor{#4}}
    \refstepcounter{section}
    \addtocontents{toc}{\protect\colorlet{toccolor-\thesection}{\tempcolor}}
    \phantomsection
    \protected@edef\@currentlabelname{#1}%
    \label{#5}%
    \section*{#1 \hfill \normalfont\small #2}
    \leavevmode\par\vspace{-\baselineskip}
    \addcontentsline{toc}{section}{%
        \texorpdfstring{%
            \protect\colorbox{toccolor-\thesection}{\makebox[0pt][l]{\hspace{-3pt}\rule[-4pt]{0pt}{14pt}}}%
            \hspace{6pt}%
            \textbf{#1} \protect\textcolor{gray}{(#2)}%
        }{#1}%
    }
    \vspace{-0.2cm}

    {\color{\@entryphasecolor}\hrule height 6pt}\smallskip
    {\noindent \small \textbf{Author:} \@entryauthor \hfill \textbf{Phase:} \@entryphase}\par
    \medskip
}

% Legend Page
\newcommand{\phaselegend}{
    \newpage
    \section*{Design Process Phases \& Formatting Guide}

    This notebook is color-coded by the phase of the engineering design process. The table of contents and the header of each entry will reflect these phases.

    \vspace{1cm}

    \phaselist

    \vspace{1cm}
    \subsection*{General Formatting}
    \begin{itemize}
        \item Keep entries in chronological order.
        \item Ensure all figures have captions.
        \item Provide detailed explanations for calculations, code logic, and design choices.
    \end{itemize}
    \newpage
}

