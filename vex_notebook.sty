% Member formatting command
\newcommand{\teammember}[3]{%
    \begin{minipage}[t]{0.45\linewidth}
        \centering
        \vspace{0.5cm}
        \begin{adjustbox}{minipage=[c][6cm][c]{5cm}, clip}
            \centering
            \ifx&#3&\else
                \adjustbox{min size={5cm}{6cm}}{\includegraphics{#3}}
            \fi
        \end{adjustbox}\par
        \vspace{0.3cm}
        {\large\textbf{#1}}\par
        {\small\textit{#2}}\par
        \vspace{0.5cm}
    \end{minipage}
}

% Title Page Generation
\newcommand{\maketeamtitle}{
