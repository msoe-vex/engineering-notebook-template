% Phase color mapping
\csdef{phasecolor@Define Problem}{PhaseDefine}
\csdef{phasecolor@Generate Concepts}{PhaseGenerate}
\csdef{phasecolor@Develop Solution}{PhaseDevelop}
\csdef{phasecolor@Construct and Test}{PhaseConstruct}
\csdef{phasecolor@Evaluate Solution}{PhaseEvaluate}

% Helper to get phase color (expandable)
\newcommand{\getphasecolor}[1]{%
    \ifcsdef{phasecolor@#1}{\csuse{phasecolor@#1}}{PhaseDefault}%
}

% Commands to set current entry info
\newcommand{\@entrytitle}{}
\newcommand{\@entrydate}{}
\newcommand{\@entryauthor}{}
\newcommand{\@entryphase}{}
\newcommand{\@entryphasecolor}{PhaseDefault}

% Command to start a new entry
% Usage: \newentry{Title}{Date}{Author}{Phase}
% Phases: Define Problem, Generate Concepts, Develop Solution, Construct and Test, Evaluate Solution
\newcommand{\newentry}[4]{
    \newpage
    \renewcommand{\@entrytitle}{#1}
    \renewcommand{\@entrydate}{#2}
    \renewcommand{\@entryauthor}{#3}
    \renewcommand{\@entryphase}{#4}

    % Determine color based on phase
    \ifthenelse{\equal{#4}{Define Problem}}{\renewcommand{\@entryphasecolor}{PhaseDefine}}{
        \ifthenelse{\equal{#4}{Generate Concepts}}{\renewcommand{\@entryphasecolor}{PhaseGenerate}}{
            \ifthenelse{\equal{#4}{Develop Solution}}{\renewcommand{\@entryphasecolor}{PhaseDevelop}}{
                \ifthenelse{\equal{#4}{Construct and Test}}{\renewcommand{\@entryphasecolor}{PhaseConstruct}}{
                    \ifthenelse{\equal{#4}{Evaluate Solution}}{\renewcommand{\@entryphasecolor}{PhaseEvaluate}}{
                        \renewcommand{\@entryphasecolor}{PhaseDefault}
                    }}}}}

    \stepcounter{tocentrycount}
    \edef\tempcolor{\getphasecolor{#4}}
    \addtocontents{toc}{\protect\colorlet{toccolor-\thetocentrycount}{\tempcolor}}
    \phantomsection
    \addcontentsline{toc}{section}{%
        \texorpdfstring{%
            \protect\colorbox{toccolor-\thetocentrycount}{\makebox[0pt][l]{\hspace{-3pt}\rule[-6pt]{0pt}{18pt}}}%
            \hspace{6pt}%
            \protect\parbox[t]{0.82\linewidth}{\textbf{#1}\newline\footnotesize \textcolor{gray}{#4 --- #3 (#2)}}%
        }{#1}%
    }
    \section*{#1}
    \vspace{-0.5cm}

    \begin{tcolorbox}[colback=\@entryphasecolor, colframe=black, boxrule=1pt, arc=0pt]
        \textbf{Project Title:} \@entrytitle \hfill \textbf{Date:} \@entrydate \\
        \textbf{Author:} \@entryauthor \hfill \textbf{Phase:} \@entryphase
    \end{tcolorbox}
    \vspace{0.5cm}
}

% Legend Page
\newcommand{\phaselegend}{
    \newpage
    \section*{Design Process Phases \& Formatting Guide}

    This notebook is color-coded by the phase of the engineering design process. The table of contents and the header of each entry will reflect these phases.

    \vspace{1cm}

    \begin{tcolorbox}[colback=PhaseDefine, colframe=black, boxrule=1pt, arc=0pt]
        \textbf{Define Problem:} Identifying the core issue, setting SMART goals, outlining constraints and deliverables.
    \end{tcolorbox}

    \begin{tcolorbox}[colback=PhaseGenerate, colframe=black, boxrule=1pt, arc=0pt]
        \textbf{Generate Concepts:} Brainstorming, research, prototyping, and decision matrices to evaluate potential solutions.
    \end{tcolorbox}

    \begin{tcolorbox}[colback=PhaseDevelop, colframe=black, boxrule=1pt, arc=0pt]
        \textbf{Develop Solution:} Creating CAD, detailed sketches, math calculations, graphical models, and pseudocode.
    \end{tcolorbox}

    \begin{tcolorbox}[colback=PhaseConstruct, colframe=black, boxrule=1pt, arc=0pt]
        \textbf{Construct and Test:} Building the robot, writing the code, executing test plans, and gathering qualitative/quantitative data.
    \end{tcolorbox}

    \begin{tcolorbox}[colback=PhaseEvaluate, colframe=black, boxrule=1pt, arc=0pt]
        \textbf{Evaluate Solution:} Reflecting on constraints, event outcomes, and planning future improvements.
    \end{tcolorbox}

    \vspace{1cm}
    \subsection*{General Formatting}
    \begin{itemize}
        \item Keep entries in chronological order.
        \item Ensure all figures have captions.
        \item Provide detailed explanations for calculations, code logic, and design choices.
    \end{itemize}
    \newpage
}

% Easy image insertion
% Usage: \image{filename}{title}{caption}
\newcommand{\image}[3]{
    \begin{figure}[htbp]
        \refstepcounter{figure}
        \blockheader{Figure \thefigure}{#2}
        \centering
        \includegraphics[max width=\textwidth, max height=0.4\textheight, keepaspectratio]{#1}
        \caption*{#3}
    \end{figure}
}

% Standardized Notebook Commands (Pre-prefixed for easy .sty customization)

% \notebookentry{Title}{Date}{Author}{Phase}
\newcommand{\notebookentry}[4]{\newentry{#1}{#2}{#3}{#4}}

% \notebookimage{filename}{title}{caption}{width_percent}{label}
\newcommand{\notebookimage}[5]{
    \begin{figure}[htbp]
        \refstepcounter{figure}
        \blockheader{Figure \thefigure}{#2}
        \label{#5}
        \centering
        \includegraphics[width=#4, max height=0.4\textheight, keepaspectratio]{#1}
        \caption*{#3}
    \end{figure}
}

% \notebooktable{columns}{title}{content}{caption}{label}
\newcommand{\notebooktable}[5]{\customtable{#1}{#2}{#3}{#4}{#5}}

% \begin{notebookcodeblock}{language}{title}{caption}{label} ... \end{notebookcodeblock}
\newcommand{\@currentcodecaption}{}
\lstnewenvironment{notebookcodeblock}[4]%
{%
    \renewcommand{\@currentcodecaption}{#3}%
    \refstepcounter{lstlisting}%
    \blockheader{Code \thelstlisting}{#2}%
    \label{#4}%
    \lstset{language=#1, basicstyle=\small\ttfamily, breaklines=true, belowskip=0pt}%
}%
{%
    \nopagebreak
    \vspace{-0.5em}
    {\centering\small\@currentcodecaption\endgraf}%
    \addvspace{1em}%
}

% Easy table insertion
% Usage: \customtable{columns}{title}{content}{caption}{label}
\newcommand{\customtable}[5]{
    \begin{table}[htbp]
        \refstepcounter{table}
        \blockheader{Table \thetable}{#2}
        \label{#5}
        \centering
        \begin{tabular}{#1}
            \hline
            #3
            \hline
        \end{tabular}
        \caption*{#4}
    \end{table}
}

% Redefine \hyperref to include automatic reference markers
\AtBeginDocument{
    \LetLtxMacro{\oldhyperref}{\hyperref}
    \DeclareRobustCommand{\hyperref}[2][]{%
        \if\relax\detokenize{#1}\relax
            \oldhyperref{#2}%
        \else
            \oldhyperref[#1]{#2} (\cref{#1})%
        \fi
    }
}
