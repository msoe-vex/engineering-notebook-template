% Redefine \hyperref to include automatic reference markers
\AtBeginDocument{
    % Light blue links
    \definecolor{linkblue}{HTML}{1E90FF}
    \hypersetup{linkcolor=linkblue, urlcolor=linkblue, citecolor=linkblue}
}

% Helper command for formatted links
% Usage: \notebooklink{text}{type}{uuid/url}
% Supported types: entry, header, image, table, codeBlock, url
\newcommand{\notebooklink}[3]{%
    \ifthenelse{\equal{#2}{url}}{%
        \href{#3}{#1}%
    }{%
        \ifcsname r@#3\endcsname
            \ifthenelse{\equal{#2}{entry}}{%
                \hyperref[#3]{#1 (\nameref*{#3}\ p.\,\pageref*{#3})}%
            }{%
                \ifthenelse{\equal{#2}{header}}{%
                    \hyperref[#3]{#1 (\nameref*{#3}\ p.\,\pageref*{#3})}%
                }{%
                    \hyperref[#3]{#1 (\cref*{#3})}%
                }%
            }%
        \else
            \hyperref[#3]{#1}%
        \fi
    }%
}

% Backward-compatible wrappers for older generated LaTeX files
\newcommand{\resourcelink}[2][]{\notebooklink{#2}{resource}{#1}}
\newcommand{\entrylink}[2][]{\notebooklink{#2}{entry}{#1}}
\newcommand{\headerlink}[2][]{\notebooklink{#2}{header}{#1}}

% Command to output a header with UUID label
% Usage: \notebookheader{text}{level}{uuid}
% level: 1 = subsection, 2 = subsubsection, etc.
\newcommand{\notebookheader}[3]{%
    \ifnum#2=1
        \subsection{#1}%
    \else
        \subsubsection{#1}%
    \fi
    \label{#3}%
}
